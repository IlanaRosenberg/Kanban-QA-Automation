{
  "info": {
    "name": "Kanban QA Automation API",
    "description": "Complete API collection for the Kanban QA Automation project. Login saves {{token}} automatically for subsequent requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "board_id", "value": "", "type": "string" },
    { "key": "card_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"email\": \"newuser@kanban.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "  console.log('Token saved:', json.data.token.substring(0, 20) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser1@kanban.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api", "auth", "me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/logout", "host": ["{{base_url}}"], "path": ["api", "auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Boards",
      "item": [
        {
          "name": "List Boards",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/boards/", "host": ["{{base_url}}"], "path": ["api", "boards", ""] }
          }
        },
        {
          "name": "Create Board",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data.id) {",
                  "  pm.collectionVariables.set('board_id', json.data.id);",
                  "  console.log('Board ID saved:', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/boards/", "host": ["{{base_url}}"], "path": ["api", "boards", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Sprint Board\",\n  \"description\": \"Sprint planning board\"\n}"
            }
          }
        },
        {
          "name": "Get Board Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/boards/{{board_id}}", "host": ["{{base_url}}"], "path": ["api", "boards", "{{board_id}}"] }
          }
        },
        {
          "name": "Update Board",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/boards/{{board_id}}", "host": ["{{base_url}}"], "path": ["api", "boards", "{{board_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Board Name\",\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete Board",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/boards/{{board_id}}", "host": ["{{base_url}}"], "path": ["api", "boards", "{{board_id}}"] }
          }
        },
        {
          "name": "Add Member",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/boards/{{board_id}}/members", "host": ["{{base_url}}"], "path": ["api", "boards", "{{board_id}}", "members"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 3,\n  \"role\": \"user\"\n}"
            }
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/boards/{{board_id}}/members/3", "host": ["{{base_url}}"], "path": ["api", "boards", "{{board_id}}", "members", "3"] }
          }
        }
      ]
    },
    {
      "name": "Cards",
      "item": [
        {
          "name": "List Cards",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/boards/{{board_id}}/cards", "host": ["{{base_url}}"], "path": ["api", "boards", "{{board_id}}", "cards"] }
          }
        },
        {
          "name": "List Cards — Filter by Column",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/boards/{{board_id}}/cards?column=In Progress",
              "host": ["{{base_url}}"],
              "path": ["api", "boards", "{{board_id}}", "cards"],
              "query": [{ "key": "column", "value": "In Progress" }]
            }
          }
        },
        {
          "name": "Create Card",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data.id) {",
                  "  pm.collectionVariables.set('card_id', json.data.id);",
                  "  console.log('Card ID saved:', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/boards/{{board_id}}/cards", "host": ["{{base_url}}"], "path": ["api", "boards", "{{board_id}}", "cards"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Fix login bug\",\n  \"description\": \"Token expiry not handled\",\n  \"column\": \"To Do\"\n}"
            }
          }
        },
        {
          "name": "Get Card Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/boards/{{board_id}}/cards/{{card_id}}", "host": ["{{base_url}}"], "path": ["api", "boards", "{{board_id}}", "cards", "{{card_id}}"] }
          }
        },
        {
          "name": "Move Card",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/boards/{{board_id}}/cards/{{card_id}}", "host": ["{{base_url}}"], "path": ["api", "boards", "{{board_id}}", "cards", "{{card_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"column\": \"In Progress\"\n}"
            }
          }
        },
        {
          "name": "Update Card Title",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/boards/{{board_id}}/cards/{{card_id}}", "host": ["{{base_url}}"], "path": ["api", "boards", "{{board_id}}", "cards", "{{card_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated card title\"\n}"
            }
          }
        },
        {
          "name": "Delete Card",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/boards/{{board_id}}/cards/{{card_id}}", "host": ["{{base_url}}"], "path": ["api", "boards", "{{board_id}}", "cards", "{{card_id}}"] }
          }
        }
      ]
    }
  ]
}
